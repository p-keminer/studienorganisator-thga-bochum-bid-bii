# ===========================================================================
# Studienorganisator — Umgebungsvariablen
# ===========================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# WICHTIG: .env wird NIEMALS in Git eingecheckt (siehe .gitignore)
# ===========================================================================

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------

# Datenbank-Pfad (relativ zum Backend-Ordner oder absolut)
# Standard: SQLite-Datei im lokalen Datenordner
DATABASE_URL=sqlite:///data/studienorganisator.db

# API-Server — NUR an localhost binden (Sicherheit!)
API_HOST=127.0.0.1
API_PORT=8321

# Debug-Modus: "true" aktiviert Auto-Reload und detaillierte Fehlermeldungen
# NIEMALS in Produktion aktivieren!
DEBUG_MODE=false

# ---------------------------------------------------------------------------
# PDF-Verarbeitung
# ---------------------------------------------------------------------------

# Maximale Upload-Größe in Megabyte
MAX_UPLOAD_SIZE_MB=50

# Standard-Parser-Profil (Dateiname ohne .json unter backend/parser_profiles/)
DEFAULT_PARSER_PROFILE=thga

# Verzeichnis für hochgeladene PDFs
UPLOAD_DIR=uploads

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------

# Backend-URL für API-Aufrufe (muss mit API_HOST:API_PORT übereinstimmen)
VITE_API_BASE_URL=http://127.0.0.1:8321

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log-Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
